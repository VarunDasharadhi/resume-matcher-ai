# Copy this file to ".env" and fill in your values.
# The app works WITHOUT any of these — it falls back to a built-in local
# analysis engine. Add an API key below to unlock AI-powered analysis.

# ── Option A: OpenRouter (recommended — has FREE models) ──────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which model to use. Defaults to a free model when using OpenRouter.
# Free options (availability changes over time — see https://openrouter.ai/models?max_price=0):
#   meta-llama/llama-3.3-70b-instruct:free   (default)
#   deepseek/deepseek-chat-v3-0324:free
#   google/gemini-2.0-flash-exp:free
#   qwen/qwen-2.5-72b-instruct:free
#   mistralai/mistral-small-3.1-24b-instruct:free
OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: shown to OpenRouter for attribution / free-tier ranking.
APP_URL=https://github.com/VarunDasharadhi/resume-matcher-ai

# ── Option B: OpenAI directly (instead of OpenRouter) ─────────────────────
# If set (and OPENROUTER_API_KEY is empty), the app uses OpenAI.
# With this option, set OPENAI_MODEL to e.g. gpt-4o-mini.
OPENAI_API_KEY=

# ── App settings ──────────────────────────────────────────────────────────
# Recommended in production: a random secret for signing session cookies.
SECRET_KEY=change-me-to-a-long-random-string

# Optional: port for local runs (default: 5000).
PORT=5000
