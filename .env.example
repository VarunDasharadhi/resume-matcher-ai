# Copy this file to ".env" and fill in your values.
# The app works WITHOUT any of these — it falls back to a built-in local
# analysis engine. Add an API key below to unlock AI-powered analysis.

# ── Option A: OpenRouter (recommended — has FREE models) ──────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which model to use. Defaults to `openrouter/free`, OpenRouter's auto-router,
# which picks whichever free model is currently healthy. Benchmarked against
# 5 pinned free models on this app's real analysis prompt (2026-07-17): every
# pinned model either rate-limited or was unreliable, while the auto-router
# succeeded every time with the lowest latency. Pinned model IDs also rot as
# the free catalog changes (see https://openrouter.ai/models?max_price=0).
# Leave this unset unless you have a specific reason to pin a model.
OPENAI_MODEL=

# Optional: shown to OpenRouter for attribution / free-tier ranking.
APP_URL=https://github.com/VarunDasharadhi/resume-matcher-ai

# ── Option B: OpenAI directly (instead of OpenRouter) ─────────────────────
# If set (and OPENROUTER_API_KEY is empty), the app uses OpenAI.
# With this option, set OPENAI_MODEL to e.g. gpt-4o-mini.
OPENAI_API_KEY=

# ── App settings ──────────────────────────────────────────────────────────
# Recommended in production: a random secret for signing session cookies.
SECRET_KEY=change-me-to-a-long-random-string

# Optional: port for local runs (default: 5000).
PORT=5000
